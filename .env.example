# =========================================================
# CFO AI — Personal AI Budget Maker
# Environment Placeholder File
# =========================================================
# Copy this file to `.env.local` for local development.
# Never commit real secrets, service-role keys, payment secrets,
# AI provider keys, or private credentials to the frontend.
# =========================================================


# ---------------------------------------------------------
# App Configuration
# ---------------------------------------------------------

VITE_APP_NAME="CFO AI"
VITE_APP_TAGLINE="Personal AI Budget Maker"
VITE_APP_ENV="development"
VITE_APP_URL="http://localhost:5173"
VITE_APP_SUPPORT_EMAIL="support@placeholder-cfo-ai.com"
VITE_APP_DEFAULT_CURRENCY="INR"
VITE_APP_DEFAULT_LOCALE="en-IN"


# ---------------------------------------------------------
# Supabase Public Client Configuration
# ---------------------------------------------------------
# These are public browser-safe values.
# Keep Supabase Service Role Keys only in Supabase Edge Functions
# or another secure backend layer.

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key-placeholder"


# ---------------------------------------------------------
# Supabase Storage Buckets
# ---------------------------------------------------------

VITE_SUPABASE_RECEIPTS_BUCKET="receipts"
VITE_SUPABASE_SHARE_CARDS_BUCKET="share-cards"
VITE_SUPABASE_EXPORTS_BUCKET="exports"
VITE_SUPABASE_AVATARS_BUCKET="avatars"


# ---------------------------------------------------------
# Supabase Edge Function Endpoints
# ---------------------------------------------------------
# AI, OCR, billing verification, and sensitive operations should
# run through Edge Functions or a secure backend — not directly
# from the frontend.

VITE_EDGE_AI_ROUTER_FUNCTION="ai-router"
VITE_EDGE_OCR_FUNCTION="receipt-ocr"
VITE_EDGE_PAYMENT_VERIFY_FUNCTION="verify-payment"
VITE_EDGE_REFERRAL_PAYOUT_FUNCTION="referral-payout"
VITE_EDGE_ADMIN_ACTIONS_FUNCTION="admin-actions"


# ---------------------------------------------------------
# AI Provider Mode
# ---------------------------------------------------------
# placeholder = no real AI provider is called.
# edge = call Supabase Edge Function router.
#
# Future production providers should be configured server-side only.

VITE_AI_MODE="placeholder"
VITE_AI_DEFAULT_TIER="light"
VITE_AI_ENABLE_REQUEST_LOGGING="true"
VITE_AI_ENABLE_COST_ESTIMATION="true"


# ---------------------------------------------------------
# Daily AI Quota Defaults
# ---------------------------------------------------------
# Final authority must be enforced in database policies/functions.
# Frontend values are only for UX display and soft guidance.

VITE_FREE_DAILY_AI_LIMIT="5"
VITE_PRO_DAILY_AI_LIMIT="50"
VITE_PREMIUM_DAILY_AI_LIMIT="200"
VITE_FAMILY_DAILY_AI_LIMIT="500"
VITE_ADMIN_DAILY_AI_LIMIT="9999"


# ---------------------------------------------------------
# Subscription / Plan Placeholders
# ---------------------------------------------------------

VITE_PLAN_FREE_PRICE="0"
VITE_PLAN_PRO_PRICE="499"
VITE_PLAN_PREMIUM_PRICE="999"
VITE_PLAN_FAMILY_PRICE="1999"
VITE_PLAN_CURRENCY="INR"


# ---------------------------------------------------------
# Payment Configuration
# ---------------------------------------------------------
# Razorpay Key ID is browser-safe.
# Razorpay Key Secret must NEVER be placed here.
# Payment verification must happen through a secure backend or
# Supabase Edge Function.

VITE_PAYMENT_MODE="placeholder"
VITE_PAYMENT_PROVIDER="razorpay"
VITE_RAZORPAY_KEY_ID="rzp_test_placeholder_public_key"


# ---------------------------------------------------------
# Referral System
# ---------------------------------------------------------
# Commission is fixed at 25%.
# Final commission calculation and payout approval must be
# validated server-side.

VITE_REFERRAL_ENABLED="true"
VITE_REFERRAL_COMMISSION_RATE="0.25"
VITE_REFERRAL_COOKIE_DAYS="30"
VITE_REFERRAL_MIN_PAYOUT_AMOUNT="1000"
VITE_REFERRAL_CURRENCY="INR"


# ---------------------------------------------------------
# Security / Privacy UX Configuration
# ---------------------------------------------------------

VITE_ENABLE_PRIVACY_MASKING="true"
VITE_ENABLE_SHARE_CARD_AMOUNT_MASKING="true"
VITE_ENABLE_AUDIT_LOGS="true"
VITE_SESSION_EXPIRY_WARNING_MINUTES="10"
VITE_MAX_RECEIPT_UPLOAD_MB="8"


# ---------------------------------------------------------
# Feature Flags - Initial Defaults
# ---------------------------------------------------------
# Final feature access should come from Supabase feature flags,
# subscription records, and role-based permissions.

VITE_FEATURE_RECEIPT_SCANNER="true"
VITE_FEATURE_AI_CHAT="true"
VITE_FEATURE_ROAST_MODE="true"
VITE_FEATURE_REFERRALS="true"
VITE_FEATURE_ADMIN_PANEL="true"
VITE_FEATURE_MOCK_PAYMENT_CHECKOUT="true"
VITE_FEATURE_SHARE_CARDS="true"
VITE_FEATURE_EXPORT_DATA="true"


# ---------------------------------------------------------
# Analytics / Monitoring Placeholders
# ---------------------------------------------------------

VITE_ANALYTICS_ENABLED="false"
VITE_ANALYTICS_PROVIDER="placeholder"
VITE_ERROR_REPORTING_ENABLED="false"
VITE_ERROR_REPORTING_DSN="placeholder-error-reporting-dsn"


# ---------------------------------------------------------
# Legal / Compliance Placeholders
# ---------------------------------------------------------

VITE_PRIVACY_POLICY_URL="/privacy"
VITE_TERMS_URL="/terms"
VITE_DISCLAIMER_URL="/disclaimer"